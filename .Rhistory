p <- murders |> ggplot(aes(population/10^6, total, label = abb))
p + geom_point(size=3) + geom_text(nudge_x = 0.05) +
scale_x_log10() + scale_y_log10() +
xlab("Populations in millions (Log Scale)") +
ylab("Total number of murders (Log Scale)") +
ggtitle(("US Gun Muders in US 2010"))
r <- murders |> summarise(rate = sum(total)/sum(population)*10^6)|> pull(rate)
p <- murders |> ggplot(aes(population/10^6, total, label = abb))
p + geom_point(size=3) + geom_text(nudge_x = 0.05) +
scale_x_log10() + scale_y_log10() +
xlab("Populations in millions (Log Scale)") +
ylab("Total number of murders (Log Scale)") +
ggtitle(("US Gun Muders in US 2010")) +
geom_abline(intercept = log10(r), lty = 1 , color = "darkgrey") +
geom_point(aes(col=region)) +
scale_color_discrete(name = "Region")
p <- murders |> ggplot(aes(population/10^6, total, label = abb)) +
geom_text(nudge_x = 0.075) +
scale_x_log10() +
scale_y_log10() +
xlab("Populations in millions (log scale)") +
ylab("Total number of murders (log scale)") +
ggtitle("US Gun Murders in US 2010")
# make colors all blue
p + geom_point(size = 3, color = "blue")
